# =====================================================
#  .env.local.example
#  環境変数テンプレート — .env.local にコピーして使用
#  ⚠️ .env.local は絶対に git にコミットしないこと
# =====================================================

# --- Notion ---
NOTION_TOKEN=secret_xxxx                         # Notion Integration トークン
NOTION_PARENT_PAGE_ID=355960a91e2381b49cb2fa02dec4ea5a  # 🏢 企業・組織 展開ページ ID
NOTION_HEARING_DB_ID=                            # ヒアリング結果管理DB ID

# --- Anthropic / Claude API ---
ANTHROPIC_API_KEY=sk-ant-xxxx

# --- LINE（問い合わせ受付用） ---
LINE_CHANNEL_SECRET=
LINE_CHANNEL_TOKEN=

# --- Supabase（BCP用） ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Cron（Notionバックアップ用） ---
CRON_SECRET=

# --- ローカルMCPゲートウェイ（Mac mini Coolify） ---
LOCAL_MCP_GATEWAY_URL=https://your-ngrok-domain.ngrok-free.dev
LOCAL_MCP_GATEWAY_SECRET=
